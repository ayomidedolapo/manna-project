generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Optional but recommended for Neon:
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum DeliveryPartner {
  KWIK
}

enum DeliveryStatus {
  CREATED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum DeliveryProcessingStatus {
  PENDING
  QUEUED
  READY_FOR_DISPATCH
  DISPATCHED
  DELIVERED
  FAILED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum VariantUnit {
  PIECE
  KG
  PAINT
  HALF_PAINT
  BASKET
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  phone        String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)

  faceImageUrl   String?
  isFaceCaptured Boolean @default(false)
  isFaceVerified Boolean @default(false)

  orders Order[]

  // ✅ persistent cart (1 cart per user)
  cart Cart?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

model Product {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  category    String
  subCategory String?

  imageUrl   String?
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  variants   ProductVariant[]
  orderItems OrderItem[]

  // ✅ cart items
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([subCategory])
  @@index([isFeatured])
}

model ProductVariant {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  name         String
  unit         VariantUnit @default(PIECE)
  unitWeightKg Float?

  priceNgn Int
  stockQty Int?

  orderItems OrderItem[]

  // ✅ cart items
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([unit])
}

model Order {
  id          String  @id @default(uuid())
  orderNumber String  @unique
  user        User?   @relation(fields: [userId], references: [id])
  userId      String?

  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING)

  totalAmountNgn Int
  deliveryFeeNgn Int

  paymentProvider  PaymentProvider?
  paymentReference String?
  paidAt           DateTime?

  deliveryAddress1 String
  deliveryAddress2 String?
  city             String
  state            String
  deliveryNote     String?
  deliveryEstimate DateTime?

  deliveryLat Float?
  deliveryLng Float?

  deliveryPartner DeliveryPartner @default(KWIK)

  faceCaptureImageUrl String?
  faceCaptureAt       DateTime?

  invoiceNumber   String?   @unique
  invoiceIssuedAt DateTime?
  receiptSentAt   DateTime?
  receiptEmailTo  String?

  // ✅ NEW: weight snapshot for ops/audit (optional but very useful)
  totalWeightKg Float?

  items    OrderItem[]
  delivery Delivery?
  payments PaymentAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

model Delivery {
  id      String @id @default(uuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String @unique

  partner DeliveryPartner @default(KWIK)
  status  DeliveryStatus  @default(CREATED)

  // ✅ ADD THESE HERE
  processingStatus       DeliveryProcessingStatus @default(PENDING)
  requiresManualDispatch Boolean                  @default(false)
  scheduledDispatchAt    DateTime?
  dispatchDeferredReason String?

  kwikTaskId      String? @unique
  kwikTrackingUrl String?
  kwikRawResponse Json?

  kwikUniqueOrderId    String?
  kwikJobStatus        Int?
  kwikStatusCheckUrl   String?
  lastWebhookAt        DateTime?
  lastStatusCheckAt    DateTime?
  statusCheckAttempts  Int       @default(0)
  nextStatusCheckAt    DateTime?
  lastStatusCheckError String?

  deliveredAt            DateTime?
  kwikLastTerminalStatus Int?

  // ✅ NEW: chosen vehicle for this delivery
  kwikVehicleId    Int?
  kwikVehicleLabel String? // BIKE | SUV | VAN
  totalWeightKg    Float? // snapshot at dispatch time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([processingStatus])
  @@index([requiresManualDispatch])
  @@index([scheduledDispatchAt])
  @@index([kwikUniqueOrderId])
  @@index([nextStatusCheckAt])
}

model DeliveryWebhookEvent {
  id       String @id @default(cuid())
  provider String @default("KWIK")

  // Deduplication hash (webhook can retry)
  dedupeHash String @unique

  jobId         String?
  uniqueOrderId String?
  jobStatus     Int?

  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  status      String    @default("RECEIVED") // RECEIVED | PROCESSED | FAILED
  error       String?

  @@index([jobId])
  @@index([uniqueOrderId])
  @@index([status])
}

model PaymentAttempt {
  id String @id @default(uuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  provider  PaymentProvider
  reference String          @unique
  status    PaymentStatus   @default(PENDING)

  amountNgn Int
  currency  String @default("NGN")

  rawInit   Json?
  rawVerify Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model OrderItem {
  id      String @id @default(uuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId String?

  quantity     Int
  unitPriceNgn Int
  subtotalNgn  Int

  createdAt DateTime @default(now())
}

model Discount {
  id          String  @id @default(uuid())
  title       String
  description String?

  type           DiscountType
  percentageOff  Int?
  fixedAmountOff Int?

  appliesToAll Boolean @default(false)
  productIds   Json?

  isActive Boolean   @default(false)
  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model B2BLead {
  id               String  @id @default(uuid())
  businessName     String
  contactPerson    String
  email            String?
  phone            String
  message          String?
  estMonthlyVolume String?

  status LeadStatus @default(NEW)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([phone])
}

model SiteSettings {
  id             Int     @id @default(1)
  companyEmail   String
  companyPhone   String
  whatsappNumber String?
  address        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ✅ Persistent Cart
// - 1 cart per user (userId is unique on Cart)
// - Prevent duplicates via unique constraint (cartId + productId + productVariantId)
//
model Cart {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CartItem {
  id String @id @default(uuid())

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId String?

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ prevents duplicates for same product+variant in same cart
  // Note: Postgres allows multiple NULLs in unique constraints,
  // so variant=null rows may still duplicate. We'll handle that in API with upsert logic.
  @@unique([cartId, productId, productVariantId])
  @@index([cartId])
  @@index([productId])
  @@index([productVariantId])
}
